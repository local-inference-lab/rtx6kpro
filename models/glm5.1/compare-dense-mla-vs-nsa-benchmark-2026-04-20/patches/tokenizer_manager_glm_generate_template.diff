@@ -617,6 +617,58 @@ class TokenizerManager(TokenizerControlMixin, TokenizerManagerScoreMixin):
         # For true batches, return as-is
         return input_ids, token_type_ids
 
+    def _should_apply_glm_chat_template(self, text: str) -> bool:
+        if not text or self.tokenizer is None:
+            return False
+
+        architectures = getattr(self.model_config.hf_config, "architectures", []) or []
+        if "GlmMoeDsaForCausalLM" not in architectures:
+            return False
+
+        if getattr(self.tokenizer, "chat_template", None) is None:
+            return False
+
+        if not hasattr(self.tokenizer, "apply_chat_template"):
+            return False
+
+        # Avoid double-wrapping prompts that are already serialized with the GLM
+        # chat template or include explicit role markers.
+        template_markers = ("<|user|>", "<|assistant|>", "[gMASK]", "<sop>")
+        return not any(marker in text for marker in template_markers)
+
+    def _maybe_apply_glm_chat_template(
+        self, texts: Union[str, List[str]]
+    ) -> Union[str, List[str]]:
+        if isinstance(texts, str):
+            if not self._should_apply_glm_chat_template(texts):
+                return texts
+            logger.info("Applying GLM chat template to raw text generate request.")
+            return self.tokenizer.apply_chat_template(
+                [{"role": "user", "content": texts}],
+                tokenize=False,
+                add_generation_prompt=True,
+                enable_thinking=False,
+            )
+
+        updated_texts = []
+        applied = False
+        for text in texts:
+            if self._should_apply_glm_chat_template(text):
+                updated_texts.append(
+                    self.tokenizer.apply_chat_template(
+                        [{"role": "user", "content": text}],
+                        tokenize=False,
+                        add_generation_prompt=True,
+                        enable_thinking=False,
+                    )
+                )
+                applied = True
+            else:
+                updated_texts.append(text)
+        if applied:
+            logger.info("Applying GLM chat template to raw text batch generate request.")
+        return updated_texts
+
     async def _tokenize_texts(
         self, texts: Union[str, List[str]], is_cross_encoder: bool = False
     ) -> Union[
